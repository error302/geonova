# ============================================================
# IDENTIFICATION & APP URLS
# ============================================================
# The public base URL of the application. Used for absolute links in emails and meta tags.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# SUPABASE CONFIGURATION
# ============================================================
# The public URL of your Supabase instance.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# The anonymous key for client-side queries (safe to expose).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# The secret service role key (NEVER EXPOSE TO CLIENT). Used for secure backend bypasses.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional direct Postgres connection for server-only jobs or migrations.
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# ============================================================
# MONETIZATION: STRIPE
# ============================================================
# The secret key for Stripe backend operations.
STRIPE_SECRET_KEY=sk_test_...
# The publishable key for Stripe Elements on the frontend.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# The webhook signing secret for verifying Stripe events securely.
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# MONETIZATION: PAYPAL
# ============================================================
# The client ID for PayPal operations.
PAYPAL_CLIENT_ID=...
# The secret client key for server-side PayPal token generation.
PAYPAL_CLIENT_SECRET=...

# ============================================================
# MONETIZATION: MOBILE MONEY (M-PESA / AIRTEL)
# ============================================================
# Consumer key provided by Daraja API for M-Pesa.
MPESA_CONSUMER_KEY=...
# Consumer secret provided by Daraja API.
MPESA_CONSUMER_SECRET=...
# The paybill or till number used to receive operations.
MPESA_SHORT_CODE=...
# The initiator username configured on the Daraja portal.
MPESA_INITIATOR_NAME=...
# The encrypted security credential for B2B or B2C.
MPESA_SECURITY_CREDENTIAL=...
# The passkey provided when registering the URLs on Daraja.
MPESA_PASSKEY=...

# Airtel Client ID.
AIRTEL_CLIENT_ID=...
# Airtel Client Secret.
AIRTEL_CLIENT_SECRET=...

# ============================================================
# PYTHON COMPUTE ENGINE
# ============================================================
# Central address of the Python Geospatial microservice.
PYTHON_COMPUTE_URL=http://localhost:8000

# ============================================================
# CACHING & RATE LIMITING
# ============================================================
# The Upstash Redis URL endpoint used for tracking rate limit windows.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# The secret token to authenticate Upstash Redis calls.
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ============================================================
# EMAIL COMMUNICATIONS
# ============================================================
# Key used to authenticate Resend API calls.
RESEND_API_KEY=re_your_key_here
# The exact verified from-email address attached to the account.
RESEND_FROM_EMAIL=GeoNova <hello@geonova.app>

# ============================================================
# MONITORING & LOGGING
# ============================================================
# An optional external endpoint to sink logs for long term storage.
NEXT_PUBLIC_LOG_ENDPOINT=
# The fully qualified Sentry DSN for error ingestion.
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
# The environment context injected into Sentry logs (e.g. production, staging).
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# ============================================================
# SEO
# ============================================================
# The code piece required to verify domain ownership via Google Search Console.
GOOGLE_SITE_VERIFICATION=your-google-verification-code

# ============================================================
# COMMUNITY / ADMIN
# ============================================================
# The WhatsApp numbers used for forwarding community texts (no + sign).
NEXT_PUBLIC_WHATSAPP_NUMBER=254700000000
# Comma-separated list of superadmin user emails. These bypass paywalls.
ADMIN_EMAILS=admin@yourdomain.com
